{
  "name": "lithania-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Warhammer 40k litany image generator — strict black & white, runs in the browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "mammoth": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.7.0",
    "prettier": "^3.9.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.7"
  }
}
